---
import type { Project } from '../data/projects';
import type { ImageMetadata } from 'astro';

interface Props {
  project: Project;
}

const { project } = Astro.props;

/* Dynamically import the image only when one is specified.
   Astro's import.meta.glob gives us optimized ImageMetadata at build time. */
const images = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/*.{png,jpg,jpeg,webp,svg}',
);

let imageSrc: string | undefined;
if (project.image) {
  const key = `../assets/${project.image}`;
  if (images[key]) {
    const mod = await images[key]();
    imageSrc = mod.default.src;
  }
}

let mobileImageSrc: string | undefined;
if (project.mobileImage) {
  const key = `../assets/${project.mobileImage}`;
  if (images[key]) {
    const mod = await images[key]();
    mobileImageSrc = mod.default.src;
  }
}

let overlayImageSrc: string | undefined;
if (project.overlayImage) {
  const key = `../assets/${project.overlayImage}`;
  if (images[key]) {
    const mod = await images[key]();
    overlayImageSrc = mod.default.src;
  }
}
---

<section id={project.slug} class="work">
  <div class="work-content">
    <div class="work-text">
      <h2 class="work-title">{project.title}</h2>
      <p class="role">{project.role}, {project.period}</p>
      <p class="work-desc">{project.description}</p>
      <div class="button-group">
        {
          project.comingSoon ? (
            <span class="get-app-button get-app-button--disabled">
              Coming soon
            </span>
          ) : (
            <a
              href={project.url}
              class="get-app-button"
              {...(project.url.startsWith('http')
                ? { target: '_blank', rel: 'noopener noreferrer' }
                : {})}
            >
              {project.urlLabel}
            </a>
          )
        }
        {
          project.caseStudyUrl && (
            <a href={project.caseStudyUrl} class="case-study-button">
              Case Study →
            </a>
          )
        }
      </div>
    </div>
    <div class="work-image">
      {
        imageSrc && (
          <div class="work-image-wrap">
            <picture>
              {mobileImageSrc && (
                <source media="(max-width: 768px)" srcset={mobileImageSrc} />
              )}
              <img
                src={imageSrc}
                alt={project.imageAlt ?? project.title}
                loading="lazy"
                class="work-image-main"
              />
            </picture>
            {overlayImageSrc && (
              <img
                src={overlayImageSrc}
                alt=""
                aria-hidden="true"
                loading="lazy"
                class={`work-image-overlay${project.mobileOverlayOnly ? ' work-image-overlay--mobile-only' : ''}`}
              />
            )}
          </div>
        )
      }
    </div>
  </div>
</section>

<style>
  .work {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 80px 0;
  }

  .work-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
  }

  .work-text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .work-image {
    height: 90vh;
    display: flex;
    align-items: center;
    justify-content: flex-end;
  }

  .work-image-wrap {
    position: relative;
    display: inline-flex;
    border-radius: 12px;
    overflow: visible;
  }

  .work-image-main {
    display: block;
    max-width: 100%;
    max-height: 90vh;
    object-fit: contain;
  }

  .work-image-overlay {
    position: absolute;
    bottom: -16px;
    right: 8%;
    width: 32%;
    border-radius: 10px;
    pointer-events: none;
  }

  .work-image-overlay--mobile-only {
    display: none;
  }

  .work h2 {
    font-family: 'Inter', sans-serif;
    font-size: clamp(28px, 5vw, 40px);
    font-weight: 800;
    margin: 0;
  }

  .work p {
    margin: 0;
    font-size: 18px;
  }

  .work .role {
    font-size: smaller;
    color: var(--muted);
  }

  .work .work-desc {
    margin-top: 1rem;
    max-width: 600px;
    line-height: 1.6;
    letter-spacing: 0.05rem;
    font-weight: 300;
  }

  .get-app-button {
    margin-top: 2rem;
    padding: 12px 24px;
    background: var(--text);
    color: #fff;
    text-decoration: none;
    border-radius: 6px;
    border: 1.5px solid transparent;
    font-weight: 500;
    transition: all 0.2s ease;
  }

  .get-app-button:hover {
    background: #333;
    transform: translateY(-1px);
    text-decoration: none;
  }

  .get-app-button:focus-visible {
    outline: 2px solid var(--text);
    outline-offset: 2px;
  }

  .get-app-button--disabled {
    background: #d0d0d0;
    color: #888;
    cursor: default;
    pointer-events: none;
  }

  .get-app-button--disabled:hover {
    background: #d0d0d0;
    transform: none;
  }

  .button-group {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    align-items: center;
    margin-top: 2rem;
  }

  .button-group .get-app-button {
    margin-top: 0;
  }

  .case-study-button {
    padding: 12px 24px;
    background: transparent;
    color: var(--text);
    text-decoration: none;
    border-radius: 6px;
    border: 1.5px solid var(--text);
    font-weight: 500;
    transition: all 0.2s ease;
  }

  .case-study-button:hover {
    background: var(--text);
    color: #fff;
    transform: translateY(-1px);
    text-decoration: none;
  }

  .case-study-button:focus-visible {
    outline: 2px solid var(--text);
    outline-offset: 2px;
  }

  @media (max-width: 768px) {
    .work {
      min-height: 100vh;
      padding: 40px 0;
      justify-content: center;
    }

    .work-content {
      grid-template-columns: 1fr;
      gap: 48px;
    }

    .work-image {
      order: 1;
      height: auto;
      justify-content: center;
      padding: 0 0 24px 0;
    }

    .work-image-wrap {
      width: 100%;
    }

    .work-image-main {
      max-height: 40vh;
      width: 100%;
      object-fit: cover;
      border-radius: 12px;
      box-shadow:
        0 20px 60px rgba(0, 0, 0, 0.18),
        0 4px 16px rgba(0, 0, 0, 0.1);
    }

    .work-image-overlay {
      width: 28%;
      bottom: -20px;
      right: 20%;
    }

    .work-image-overlay--mobile-only {
      display: block;
    }

    .work-text {
      order: 2;
      align-items: center;
      text-align: center;
    }
  }
</style>
